server {
    listen 80;

    location / {
        proxy_pass http://frontend:5173;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }

    location /api/auth/ {
        proxy_pass http://auth-service:3001/api/auth/;
    }

    location /api/users/ {
        proxy_pass http://user-service:3002/api/users/;
    }

    location /api/projects/ {
        proxy_pass http://project-service:3003/api/projects/;
    }

    location /api/tasks/ {
        proxy_pass http://task-service:3004/api/tasks/;
    }

    location /socket.io/ {
        proxy_pass http://notification-service:3005/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
    }
}